---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"span"> {}

const { class: className, ...rest } = Astro.props;
---

<span
    class={`inline-flex items-center px-3 py-1 text-md font-bold text-white bg-(--blue-gray-color) rounded-(--badge-border-radius) ${className || ""}`}
    data-slot="badge"
    {...rest}
>
    <slot />
</span>
