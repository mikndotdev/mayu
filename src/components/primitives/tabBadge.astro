---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...rest } = Astro.props;
---

<div
    class={`absolute ${className || ""}`}
    style="font-size: 13px; font-weight: bold; top: 0; height: 24px; line-height: 24px; left: 0; border-radius: 6px 6px 0 0; padding: 0 1em 0 0.8em; display: inline-flex; align-items: center; transform: translateY(-100%);"
    data-slot="tab-badge"
    {...rest}
>
    <slot />
</div>
