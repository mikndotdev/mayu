---
import { tv, type VariantProps } from "tailwind-variants/lite";

interface Props extends VariantProps<typeof chatBubble> {
    icon: string;
    class?: string;
}

const {
    icon,
    iconVariant = "rounded",
    position = "left",
    bubbleVariant = "normal",
    class: className
} = Astro.props;

const chatBubble = tv({
    slots: {
        container: "flex flex-col md:flex-row gap-2 md:gap-4 items-start my-4 overflow-visible",
        icon: "flex-shrink-0 w-16 h-16 md:w-24 md:h-24 border-2 border-[var(--basic-border-color)] overflow-hidden flex items-center justify-center",
        iconImage: "w-full h-full object-cover",
        bubble: "relative flex-1 px-4 py-3 md:px-6 md:py-4 rounded-lg overflow-visible",
    },
    variants: {
        iconVariant: {
            rounded: {
                icon: "rounded-full",
            },
            square: {
                icon: "rounded-md",
            },
        },
        position: {
            left: {
                container: "flex-row",
                bubble: "bubble-left",
            },
            right: {
                container: "flex-row-reverse",
                bubble: "bubble-right",
            },
        },
        bubbleVariant: {
            normal: {
                bubble: "bg-[var(--white-color)] border-2 border-[var(--custom-border-color)] text-[var(--custom-text-color)] bubble-normal",
            },
            flat: {
                bubble: "bg-[var(--custom-background-color)] text-[var(--custom-text-color)] bubble-flat",
            },
            line: {
                bubble: "bg-[var(--line-chat-color)] text-[var(--custom-text-color)] bubble-line",
            },
        },
    },
    defaultVariants: {
        iconVariant: "rounded",
        position: "left",
        bubbleVariant: "normal",
    },
});

const styles = chatBubble({ iconVariant, position, bubbleVariant });
---

<div class={styles.container({ class: className })} data-slot="chatbubble">
    <div class={styles.icon()}>
        <img src={icon} alt="Chat icon" class={styles.iconImage()} />
    </div>
    <div class={styles.bubble()}>
        <slot />
    </div>
</div>

<style is:global>
    /* Speech bubble pointer - left position */
    .bubble-left.bubble-normal::before {
        content: "";
        position: absolute;
        left: -10px;
        top: 20px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 10px 10px 0;
        border-color: transparent var(--custom-border-color) transparent transparent;
        z-index: 1;
    }

    .bubble-left.bubble-normal::after {
        content: "";
        position: absolute;
        left: -8px;
        top: 21px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 9px 9px 9px 0;
        border-color: transparent var(--white-color) transparent transparent;
        z-index: 2;
    }

    .bubble-left.bubble-flat::before {
        content: "";
        position: absolute;
        left: -10px;
        top: 20px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 10px 10px 0;
        border-color: transparent var(--custom-background-color) transparent transparent;
        z-index: 1;
    }

    .bubble-left.bubble-line::before {
        content: "";
        position: absolute;
        left: -10px;
        top: 20px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 10px 10px 0;
        border-color: transparent var(--line-chat-color) transparent transparent;
        z-index: 1;
    }

    /* Speech bubble pointer - right position */
    .bubble-right.bubble-normal::before {
        content: "";
        position: absolute;
        right: -10px;
        top: 20px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 0 10px 10px;
        border-color: transparent transparent transparent var(--custom-border-color);
        z-index: 1;
    }

    .bubble-right.bubble-normal::after {
        content: "";
        position: absolute;
        right: -8px;
        top: 21px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 9px 0 9px 9px;
        border-color: transparent transparent transparent var(--white-color);
        z-index: 2;
    }

    .bubble-right.bubble-flat::before {
        content: "";
        position: absolute;
        right: -10px;
        top: 20px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 0 10px 10px;
        border-color: transparent transparent transparent var(--custom-background-color);
        z-index: 1;
    }

    .bubble-right.bubble-line::before {
        content: "";
        position: absolute;
        right: -10px;
        top: 20px;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 0 10px 10px;
        border-color: transparent transparent transparent var(--line-chat-color);
        z-index: 1;
    }
</style>