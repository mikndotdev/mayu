            "pocket-outline": "border-[var(--pocket-color)]",
            "line-outline": "border-[var(--line-color)]",
            "linkedin-outline": "border-[var(--linkedin-color)]",
            "website-outline": "border-[var(--website-color)]",
            "instagram-outline": "border-[var(--instagram-color)]",
            "pinterest-outline": "border-[var(--pinterest-color)]",
            "youtube-outline": "border-[var(--youtube-color)]",
            "tiktok-outline": "border-[var(--tiktok-color)]",
            "note-outline": "border-[var(--note-color)]",
