            "light-green-outline": "border-[var(--light-green-color)]",
            "lime-outline": "border-[var(--lime-color)]",
            "yellow-outline": "border-[var(--yellow-color)]",
            "amber-outline": "border-[var(--amber-color)]",
            "orange-outline": "border-[var(--orange-color)]",
            "deep-orange-outline": "border-[var(--deep-orange-color)]",
            "brown-outline": "border-[var(--brown-color)]",
