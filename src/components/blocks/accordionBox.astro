            black: "border-[var(--black-color)]",
            white: "border-[var(--white-color)]",
            "watery-blue": "border-[var(--watery-blue-color)]",
            "watery-yellow": "border-[var(--watery-yellow-color)]",
            "watery-red": "border-[var(--watery-red-color)]",
