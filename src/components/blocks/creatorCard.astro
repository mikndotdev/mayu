---
import CreatorCardPrimitive from "@/components/primitives/creatorCard.astro";
import type { VariantProps } from "tailwind-variants/lite";
import type { creatorCard } from "@/components/primitives/creatorCard.astro";
import creators from "@/creators.json";

interface Props extends VariantProps<typeof creatorCard> {
    id: string;
}

const { id, variant } = Astro.props;

const creator = creators.find((c) => c.id === id);

if (!creator) {
    throw new Error(`Creator with id "${id}" not found`);
}
---

<CreatorCardPrimitive
    id={creator.id}
    name={creator.name}
    description={creator.description}
    avatar={creator.avatar}
    socials={creator.socials}
    variant={variant}
/>
