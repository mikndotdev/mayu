---
import Layout from "@/layouts/Layout.astro";
import CreatorCard from "@/components/blocks/creatorCard.astro";
import BlogCard from "@/components/blocks/blogCard.astro";
import SidebarContent from "@/components/blocks/sidebarContent.astro";
import MobileMenu from "@/components/navigation/mobileMenu";
import creators from "@/creators.json";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    return creators.map(creator => ({
        params: { id: creator.id },
        props: { creator },
    }));
}

const { creator } = Astro.props;

const allPosts = await getCollection('blog');
const creatorPosts = allPosts
    .filter(post => post.data.creator === creator.id)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recentPosts = allPosts
    .filter(p => p.data.creator !== creator.id)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 5);
---
<Layout
    title={`${creator.name} - Creator`}
    description={creator.description}
    image={creator.avatar}
    url={Astro.url.pathname}
>
<div class="flex flex-row justify-center items-stretch w-full md:w-2/3 min-h-screen mx-auto md:space-x-5 py-5">
    <div class="w-full md:w-3/4 bg-white px-5 py-10">
        <CreatorCard id={creator.id} variant="blue" />

        <div class="mt-8">
            <h2 class="text-2xl font-bold mb-6">記事一覧</h2>
            {creatorPosts.length > 0 ? (
                <div class="space-y-6">
                    {creatorPosts.map((post) => (
                        <BlogCard url={post.id} />
                    ))}
                </div>
            ) : (
                <p class="text-(--pallid-text-color) text-center py-10">
                    このクリエイターの記事はまだありません。
                </p>
            )}
        </div>
    </div>
    <div class="hidden md:block w-1/4 bg-gray-200">
        <div class="sticky top-5 max-h-[calc(100vh-2.5rem)] overflow-y-auto">
            <SidebarContent recentPosts={recentPosts} />
        </div>
    </div>
</div>

<div id="mobile-sidebar-content" class="hidden">
    <SidebarContent recentPosts={recentPosts} />
</div>

<MobileMenu client:load />
</Layout>
